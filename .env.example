# --- Gmail SMTP (free, no third-party email service) ---
# 1. Enable 2-Step Verification on the Google account.
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Copy this file to ".env" and fill in the values below.
#
# If these are left blank, the server uses a free Ethereal test inbox
# (emails aren't really delivered — a preview link is logged instead).

GMAIL_USER=sankalpsandeepsingh@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Where contact-form messages are delivered:
CONTACT_TO=sankalpsandeepsingh@gmail.com

# Port the mail server listens on (must match the Vite proxy):
PORT=3001
